generator client {
  provider = "prisma-client-js"
  //previewFeatures = ["driverAdapters"]
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}
model User {
  id            Int           @id @default(autoincrement())
  name          String
  email         String        @unique
  phone         String?       @unique
  password      String
  createdAT     DateTime      @default(now())
  updateAt DateTime @updatedAt

  @@map("users")
}